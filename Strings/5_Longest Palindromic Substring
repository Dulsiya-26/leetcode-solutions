/*
# Longest Palindromic Substring

## Approach

This solution uses the **Expand Around Center** technique.
For every character in the string, we expand around:

* `(i, i)` → odd length palindrome
* `(i, i+1)` → even length palindrome

During expansion, if characters match, we keep expanding and update the longest palindrome found.

## Complexity

* **Time Complexity:** O(n²)
* **Space Complexity:** O(1)

## Language

C++
*\
class Solution {
public:
    string ans = "";

    void expand(string &s , int left ,int right) {
        while(left >= 0 && right < s.size()) {
            if(s[left] != s[right])
                break;
            left--, right++;
        }
        if(ans.size() < right - left - 1)
            ans = s.substr(left + 1 , right - left - 1);
    }

    string longestPalindrome(string s) {
        for(int i = 0 ; i < s.size() ; i++) {
            expand(s , i , i);     // odd length palindrome
            expand(s , i , i+1);   // even length palindrome
        }
        return ans;
    }
};
