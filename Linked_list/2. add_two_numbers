// Problem: Add Two Numbers
// Platform: LeetCode
// Link: https://leetcode.com/problems/add-two-numbers/

// Problem Description:
// You are given two non-empty linked lists representing two non-negative integers.
// The digits are stored in reverse order, and each node contains a single digit.
// Add the two numbers and return the sum as a linked list.

// Approach:
// We traverse both linked lists simultaneously and add corresponding digits.
// A carry variable is used to handle sums greater than 9.
// A dummy node is created to simplify the construction of the result linked list.
// For each step, we create a new node with the digit (sum % 10) and update the carry (sum / 10).
// The process continues until both lists are completely traversed and no carry remains.

// Time Complexity: O(max(n, m))
// Where n and m are the lengths of the two linked lists.
// We traverse each list once.

// Space Complexity: O(max(n, m))
// A new linked list is created to store the result.

/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode() : val(0), next(nullptr) {}
 *     ListNode(int x) : val(x), next(nullptr) {}
 *     ListNode(int x, ListNode *next) : val(x), next(next) {}
 * };
 */
class Solution {
public:
    ListNode* addTwoNumbers(ListNode* l1, ListNode* l2) {
        ListNode* dummy=new ListNode();
        ListNode* temp=dummy;
        int carry=0;
        while(l1!=NULL || l2!=NULL || carry){
            int sum=0;
            if(l1!=NULL){
                sum+=l1->val;
                l1=l1->next;
            }
            if(l2!=NULL){
                sum+=l2->val;
                l2=l2->next;
            }
            sum+=carry;
            carry=sum/10;
            ListNode* newnode=new ListNode(sum%10);
            temp->next=newnode;
            temp=temp->next;
        }
        return dummy->next;
    }
};
